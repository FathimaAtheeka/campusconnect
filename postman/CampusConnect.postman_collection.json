{
  "info": {
    "name": "CampusConnect API",
    "_postman_id": "cc-001-campusconnect",
    "description": "CampusConnect — Auth, Users (admin), Lost & Found items.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "itemId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);",
                  "if (json.user && json.user._id) pm.collectionVariables.set('userId', json.user._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nimal Perera\",\n  \"email\": \"nimal@uni.lk\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);",
                  "if (json.user && json.user._id) pm.collectionVariables.set('userId', json.user._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nimal@uni.lk\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users?page=1&limit=10"
          }
        },
        {
          "name": "Update role",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/users/{{userId}}/role",
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"admin\"\n}" }
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        }
      ]
    },
    {
      "name": "Items (Lost & Found)",
      "item": [
        {
          "name": "List items",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/items?type=lost&page=1&limit=10"
          }
        },
        {
          "name": "Create item (with image)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.item && json.item._id) pm.collectionVariables.set('itemId', json.item._id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/items",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Black backpack", "type": "text" },
                { "key": "description", "value": "Lost near the library", "type": "text" },
                { "key": "type", "value": "lost", "type": "text" },
                { "key": "category", "value": "bag", "type": "text" },
                { "key": "location", "value": "Main Library", "type": "text" },
                { "key": "image", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Get item",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/items/{{itemId}}" }
        },
        {
          "name": "Update item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/items/{{itemId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Black backpack (updated)\",\n  \"description\": \"Found near library entrance\",\n  \"type\": \"found\"\n}"
            }
          }
        },
        {
          "name": "Claim item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/items/{{itemId}}/claim"
          }
        },
        {
          "name": "Delete item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/items/{{itemId}}"
          }
        }
      ]
    }
  ]
}
